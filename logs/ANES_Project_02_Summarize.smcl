. ************************************************
. * Generating coded age variable for summary stats
. ************************************************
. 
.                 egen age_group = cut(age), at(18, 24, 40, 56, 75, 81) label
{txt}
{com}.                 label define age_lbl ///
>                 0 "18–23 (Gen Z)" ///
>                 1 "24–39 (Millennials)" ///
>                 2 "40–55 (Gen X)" ///
>                 3 "56–74 (Boomers)" ///
>                 4 "75–80+ (Silent+)"
{txt}
{com}.                 label values age_group age_lbl
{txt}
{com}.   
