{txt}
{com}.                 label variable fb_post "Facebook political post frequency (0 = Never/Not a User, 7=Always)"
{txt}
{com}.                 label variable x_post "X political post frequency (0 = Never/Not a User, 7=Always)"
{txt}
{com}.         
. 
. ************************************************
. * Creating collapsed frequency catergories 
. ************************************************
. * creating collapsed frequency categories for cleaner analysis
. * 0 = Not at all, 1 = Infrequent (less than weekly), 
. * 2 = Weekly, 3 = Daily or more
. ************************************************
. 
.         * generating collapsed frequency variables
.                 gen fb_freq_cat = .
{txt}(8,947 missing values generated)

{com}.                 replace fb_freq_cat = 0 if fb_freq == 0  // Not at all
{txt}(2,218 real changes made)

{com}.                 replace fb_freq_cat = 1 if inrange(fb_freq, 1, 2)  // Less than once a month, once or twice a month
{txt}(916 real changes made)

{com}.                 replace fb_freq_cat = 2 if inrange(fb_freq, 3, 4)  // About once a week, few times each week
{txt}(1,287 real changes made)

{com}.                 replace fb_freq_cat = 3 if inrange(fb_freq, 5, 7)  // About once a day or more
{txt}(4,526 real changes made)

{com}.                         
.                 gen fb_post_cat = .
{txt}(8,947 missing values generated)

{com}.                 replace fb_post_cat = 0 if fb_post == 0 // Non-user
{txt}(2,218 real changes made)

{com}.                 replace fb_post_cat = 1 if fb_post == 1 // Never posts (but is user)
{txt}(4,385 real changes made)

{com}.                 replace fb_post_cat = 2 if inrange(fb_post, 2, 3) // Sometimes/about half
{txt}(2,118 real changes made)

{com}.                 replace fb_post_cat = 3 if inrange(fb_post, 4, 5) // Most of time/always
{txt}(226 real changes made)

{com}.                         
.                         
.                 gen x_freq_cat = .
{txt}(8,947 missing values generated)

{com}.                 replace x_freq_cat = 0 if x_freq == 0 // Not at all
{txt}(6,175 real changes made)

{com}.                 replace x_freq_cat = 1 if inrange(x_freq, 1, 2) // Less than once a month, once or twice a month
{txt}(1,256 real changes made)

{com}.                 replace x_freq_cat = 2 if inrange(x_freq, 3, 4) // About once a week, few times each week
{txt}(628 real changes made)

{com}.                 replace x_freq_cat = 3 if inrange(x_freq, 5, 7) // About once a day or more
{txt}(888 real changes made)

{com}.                         
.                 gen x_post_cat = .
{txt}(8,947 missing values generated)

{com}.                 replace x_post_cat = 0 if x_post == 0  // Non-user
{txt}(6,175 real changes made)

{com}.                 replace x_post_cat = 1 if x_post == 1  // Never posts (but is user)
{txt}(2,088 real changes made)

{com}.                 replace x_post_cat = 2 if inrange(x_post, 2, 3)  // Sometimes/about half
{txt}(510 real changes made)

{com}.                 replace x_post_cat = 3 if inrange(x_post, 4, 5)  // Most of time/always
{txt}(174 real changes made)

{com}.                         
.         * labeling variables
.                 label define freq_cat_lbl ///
>                         0 "Not at all" ///
>                         1 "Infrequent (less than weekly)" ///
>                         2 "Weekly" ///
>                         3 "Daily or more"
{txt}
{com}.                                 
.                 label define post_cat_lbl ///
>                         0 "Non-user/Never posts" ///
>                         1 "User, never posts political content" ///
>                         2 "Occasional political posting" ///
>                         3 "Frequent political posting"
{txt}
{com}.                                 
.                 label values fb_freq_cat freq_cat_lbl
{txt}
{com}.                 label variable fb_freq_cat "Facebook usage (collapsed categories)"
{txt}
{com}.                 label values fb_post_cat post_cat_lbl
{txt}
{com}.                 label variable fb_post_cat "Political post frequency (collapsed categories)"
{txt}
{com}.                 
.                 label values x_freq_cat freq_cat_lbl
{txt}
{com}.                 label variable x_freq_cat "X usage (collapsed categories)"
{txt}
{com}.                 label values x_post_cat post_cat_lbl
{txt}
{com}.                 label variable x_post_cat "Political post frequency (collapsed categories)"
{txt}
{com}. 
