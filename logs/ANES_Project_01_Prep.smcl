. ************************************************
. * Creating and labeling binary variables
. ************************************************
. 
.                 gen fb_use = (fb_freq > 0) if !missing(fb_freq)
{txt}
{com}.                 label variable fb_use "Uses Facebook (any frequency)"
{txt}
{com}.                 label define fbuse_lbl 0 "Not a Facebook user" 1 "Facebook User"
{txt}
{com}.                 label values fb_use fbuse_lbl
{txt}
{com}. 
.                 gen x_use = (x_freq > 0) if !missing(x_freq)    
{txt}
{com}.                 label variable x_use "Uses X (any frequency)"
{txt}
{com}.                 label define xuse_lbl 0 "Not a X user" 1 "X user"
{txt}
{com}.                 label values x_use xuse_lbl
{txt}
{com}. 
.         * coding gender dummy
.            replace female = female - 1
{txt}(8,947 real changes made)

{com}.            label define fem_lbl ///
>            0 "Male" ///
>            1 "Female"
{txt}
{com}.            label values female fem_lbl
{txt}
{com}.    
. *************************************************
. * Creating polarization variable
. *************************************************
. * measures absolute difference in feeling thermometers
. * higher values = greater difference in party evaluations
. *************************************************
. 
.            gen aff_polar = . 
{txt}(8,947 missing values generated)

{com}.            replace aff_polar = abs(dem_thermo - rep_thermo) if inlist(party_id, 1,2,3,4)  // Democrats and Independents
{txt}(5,073 real changes made)

{com}.            replace aff_polar = abs(rep_thermo - dem_thermo) if inlist(party_id, 5,6,7)  // Republicans
{txt}(3,874 real changes made)

{com}.                    
